# Quran Semantic Search - Environment Configuration

# Model Configuration
MODEL_DIR=models/v1
MODEL_NAME=multilingual-e5-large

# Search Configuration
DEFAULT_TOP_K=5
MAX_TOP_K=20

# Logging
LOG_LEVEL=INFO

# Data Paths
DATA_DIR=data
MODELS_DIR=models

# Feature Flags (for future versions)
ENABLE_TAFSEER=False
ENABLE_HYBRID_SEARCH=False
ENABLE_ONTOLOGY=False

# Streamlit Configuration
STREAMLIT_CLIENT_THEME_MODE=light
STREAMLIT_LOGGER_LEVEL=info

# Optional: API Configuration (if deploying as API)
# API_HOST=0.0.0.0
# API_PORT=8000
